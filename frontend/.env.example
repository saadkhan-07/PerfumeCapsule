# Frontend environment variables. Copy to `.env` and fill in.
# Vite only exposes vars prefixed with VITE_ to the client bundle —
# never put secrets here (anything here ships to the browser).

# Base URL of the backend API (includes the /api prefix).
VITE_API_URL=http://localhost:5000/api

# WhatsApp number in international format, no +, spaces or dashes (e.g. 923001234567).
# Used in Phase 5 to build the wa.me checkout link.
VITE_WHATSAPP_NUMBER=

# Cloudinary cloud name (for constructing image URLs if needed on the client).
VITE_CLOUDINARY_CLOUD_NAME=
