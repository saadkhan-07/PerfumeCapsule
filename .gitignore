# ---------------------------------------------------------------------------
# Perfume Capsules — root .gitignore
# ---------------------------------------------------------------------------

# Dependencies
node_modules/
**/node_modules/

# Environment files — NEVER commit secrets (CLAUDE.md security rule)
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# Build output
dist/
build/
**/dist/
**/build/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Prisma
# (migrations ARE committed; only ignore generated client if it lands in-tree)
**/generated/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Vite / frontend cache
.vite/
*.local

# Coverage / temp
coverage/
*.tmp
