// ===========================================================================
// Perfume Capsules — Prisma schema
// Phase 1: Database Foundation
//
// Conventions:
//   - Primary keys: cuid() strings (non-sequential, not enumerable — security rule)
//   - Every model has createdAt + updatedAt timestamps
//   - Money is stored as Decimal(10,2), never Float
//   - Indexes are added on every foreign key and on frequently queried fields
//   - Cloudinary assets store BOTH publicId and url (secure_url)
// ===========================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  JAZZCASH
  EASYPAISA
}

// ---------------------------------------------------------------------------
// Users & Admins
// ---------------------------------------------------------------------------

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  password String // bcrypt hash — never plaintext
  name     String
  phone    String?

  // Relations
  wishlist            Wishlist[]
  reviews             Review[]
  orders              Order[]
  passwordResetTokens PasswordResetToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

// ---------------------------------------------------------------------------
// Password reset tokens (customer accounts only — NOT admins)
//
// A separate table (rather than fields on User) so a reset link can be
// invalidated and cleaned up independently. Only the SHA-256 HASH of the token
// is stored — the raw token exists solely in the emailed link, never at rest.
// ---------------------------------------------------------------------------

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique // SHA-256 hash of the token (raw token never stored)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String // bcrypt hash — never plaintext
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

// ---------------------------------------------------------------------------
// Site configuration (singleton)
//
// Holds editable, site-wide presentation/details. Enforced as a single row via a
// fixed primary key default ("singleton"): a second insert violates the PK.
// NOTE: the WhatsApp order-redirect number is intentionally NOT stored here —
// it lives in the backend WHATSAPP_NUMBER env var (single source of truth).
// Payment account details are intentionally excluded as well.
// ---------------------------------------------------------------------------

model SiteSettings {
  id String @id @default("singleton")

  // Identity
  siteName     String
  tagline      String?
  logoUrl         String? // Cloudinary secure_url
  logoPublicId    String? // Cloudinary public_id
  faviconUrl      String? // Cloudinary secure_url
  faviconPublicId String? // Cloudinary public_id

  // Contact
  contactEmail String?
  contactPhone String?

  // Address
  addressLine String?
  city        String?

  // Social
  instagramUrl String?
  facebookUrl  String?
  tiktokUrl    String?

  // Commerce
  currency String @default("PKR")

  // Shipping rule — applied at checkout, backend-authoritative (never trust the client).
  // Resolution order in order.service:
  //   1. subtotal > freeShippingThreshold        → free (0)
  //   2. city matches localCity (normalized)      → localShippingFee
  //   3. otherwise                                → outstationShippingFee
  // Values are admin-editable; the rule itself is fixed in code.
  localCity             String   @default("Lahore")
  localShippingFee      Decimal  @default(200) @db.Decimal(10, 2)
  outstationShippingFee Decimal  @default(400) @db.Decimal(10, 2)
  freeShippingThreshold Decimal? @default(5000) @db.Decimal(10, 2)

  // Ops
  announcementBar String?
  maintenanceMode Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Catalog: Brand → Product → (Variant, Image) and Product ↔ Category (M:N)
// ---------------------------------------------------------------------------

model Brand {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String?

  // Cloudinary brand logo
  logoPublicId String?
  logoUrl      String?

  // Relations
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model Product {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  isActive    Boolean @default(true)

  // Relations
  brandId      String
  brand        Brand             @relation(fields: [brandId], references: [id], onDelete: Restrict)
  variants     ProductVariant[]
  images       ProductImage[]
  categories   ProductCategory[]
  reviews      Review[]
  wishlistedBy Wishlist[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId])
  @@index([slug])
  @@index([name])
  @@index([isActive])
}

model ProductVariant {
  id    String  @id @default(cuid())
  size  String // e.g. "5ml", "10ml", "30ml" — sizes always come from variants
  price Decimal @db.Decimal(10, 2)
  stock Int     @default(0)
  sku   String? @unique

  // Relations
  productId  String
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, size])
  @@index([productId])
}

model ProductImage {
  id       String @id @default(cuid())
  publicId String // Cloudinary public_id
  url      String // Cloudinary secure_url
  position Int    @default(0) // ordering within the gallery

  // Relations
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

model Category {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  // Relations
  products ProductCategory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

// Explicit join table for the Product ↔ Category many-to-many relation.
model ProductCategory {
  productId  String
  categoryId String

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([productId, categoryId])
  @@index([productId])
  @@index([categoryId])
}

// ---------------------------------------------------------------------------
// Engagement: Wishlist & Reviews
// ---------------------------------------------------------------------------

model Wishlist {
  id String @id @default(cuid())

  userId    String
  productId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId]) // a product can be wishlisted once per user
  @@index([userId])
  @@index([productId])
}

model Review {
  id      String  @id @default(cuid())
  rating  Int // 1–5, enforced in the validator/service layer
  comment String?

  userId    String
  productId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId]) // one review per user per product
  @@index([productId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Orders: Order → OrderItem
//
// Shipping details are captured per-order (the checkout collects them).
// OrderItem stores price/name/size SNAPSHOTS so historical orders stay correct
// even if a variant's price changes or the variant/product is later deleted.
// ---------------------------------------------------------------------------

model Order {
  id String @id @default(cuid())

  // Optional owner — supports guest checkout; order is retained if the user is deleted.
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Shipping information
  customerName  String
  customerPhone String
  address       String
  city          String

  paymentMethod PaymentMethod
  status        OrderStatus   @default(PENDING)

  // Money breakdown — snapshotted at checkout so historical orders stay correct
  // even if shipping settings change later. total = subtotal + shippingFee.
  subtotal    Decimal @db.Decimal(10, 2)
  shippingFee Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)

  whatsappUrl String? // wa.me URL constructed by the backend at order creation

  // Relations
  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id String @id @default(cuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Variant link is optional + SetNull so an admin can delete a variant/product
  // without destroying historical orders. Snapshots below preserve the details.
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  // Snapshots taken at purchase time
  productName String
  size        String
  unitPrice   Decimal @db.Decimal(10, 2)
  quantity    Int
  lineTotal   Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([variantId])
}
